# ================================================
# Perfiles Spring Boot — Tzompcomer API
# ================================================
#
# LOCAL (IntelliJ, sin variables):
#   Perfil por defecto: h2 (memoria, importa Excel al arrancar)
#
# NEON / PRODUCCIÓN (Render):
#   SPRING_PROFILES_ACTIVE=prod
#   SPRING_DATASOURCE_URL=jdbc:postgresql://xxx.neon.tech/neondb?sslmode=require
#
# LOCAL contra Neon (IntelliJ Run Configuration → Environment):
#   SPRING_PROFILES_ACTIVE=prod
#   SPRING_DATASOURCE_URL=<tu URL de Neon>

spring.application.name=api
spring.profiles.default=h2
server.port=${PORT:8080}
catalog.auto-import=true
