# ================================================
# EJEMPLO de application.properties
# ================================================
# Copia este archivo como application.properties y llena tus datos

spring.application.name=api

# --- BASE DE DATOS ---
# Opción 1: PostgreSQL (Producción)
# spring.datasource.url=jdbc:postgresql://localhost:5432/tzompcomer
# spring.datasource.username=tu_usuario
# spring.datasource.password=tu_contraseña
# spring.jpa.hibernate.ddl-auto=update

# Opción 2: H2 (Desarrollo - Base de Datos en Memoria)
spring.datasource.url=jdbc:h2:mem:tzompcomerdb
spring.datasource.driverClassName=org.h2.Driver
spring.datasource.username=sa
spring.datasource.password=
spring.h2.console.enabled=true
spring.h2.console.path=/h2-console
spring.jpa.database-platform=org.hibernate.dialect.H2Dialect
spring.jpa.hibernate.ddl-auto=create-drop

# --- JPA / HIBERNATE ---
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true

# --- CARGA DE ARCHIVOS ---
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB
